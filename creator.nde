<deFrame> = <content, TS, 0>
LINE = [all], <deFrame, PTL>, <deFrame, PTR>, #000000
LINE =[all], <de_*_frame_1, PTR>, <de_*_frame_1, PBR>, #000000
LINE =[all], <de_*_frame_2, PTR>, <de_*_frame_2, PBR>, #000000
LINE =[all], <de_*_frame_3, PTR>, <de_*_frame_3, PBR>, #000000
TEXT = [all], "{1d100}", <de_*_frame_*>, center, wwcenter

;TEXT = [all], "[{CONCAT1(TOKENIZE(Á,1,_),TOKENIZE(Á,6,_))}]", <*_*_*_*_frame_*>, center, wwcenter