;BORDER=RECTANGLE,#000000,0.2
UNIT=MM
PAGE=210,297,LANDSCAPE,HV
DPI=300
CARDSIZE=63,88
;BASERANGE=,ON

LINKCSV=ANSI
LINKSEP=,
LINK=runestones-data.csv, action, theme, lieu, descriptionLieu, trouble, role, objectif, descriptionPerso, actionCombat, contrecoup, rebondissement

[n] = {(action) / 4} ;; Indiquez le nombre de cartes
CARDS = [n]
[all] = 1 - [n]

; CrÚer les sequences de donnÚes
[set(count)]%,(count),1,4 = autorange([n])
[action(count)]%,(count),1,4 = labelsub([action], [set{(count)}])
[theme(count)]%,(count),1,4 = labelsub([theme], [set{(count)}])
[lieu(count)]%,(count),1,2 = labelsub([lieu], [set{(count)}])
[descriptionLieu(count)]%,(count),1,2 = labelsub([descriptionLieu], [set{(count)}])
[trouble(count)]%,(count),1,2 = labelsub([trouble], [set{(count)}])
[role(count)]%,(count),1,2 = labelsub([role], [set{(count)}])
[objectif(count)]%,(count),1,2 = labelsub([objectif], [set{(count)}])
[descriptionPerso(count)]%,(count),1,4 = labelsub([descriptionPerso], [set{(count)}])

;; DÚfinir les frames
<header> = 0, 0, 100%, 8%
<content> = 4%, 10%, 92%, 88%

;; Header
RECTANGLE = [all], <header>, #4e7079
;; Content
EDGE = [all], CUSTOM, OSSS, ROUND
FONT = Arial, 9, TX, #000000

[content_marginX] = 4%
[content_startY] = 10%
[block_sizeX] = 23%
[block_sizeY] = 7%

{[info_structure] = "action_1_1_4|
    theme_2_1_4|
    lieu_3_2_2|
    descriptionLieu_4_2_2|
    trouble_5_2_2|
    role_6_2_2|
    objectif_7_2_2|
    descriptionPerso_8_1_4|
    actionCombat_9_4_1|
    contrecoup_10_4_1|
    rebondissement_11_4_1|
    de_12_1_4"}
{[(type_l_p_n)_frame_]%,(type_l_p_n), [info_structure] = framebar(
    {[content_marginX]+TOKENIZE((type_l_p_n),3,_)*[block_sizeX]/2},
    {[content_startY]+((2*TOKENIZE((type_l_p_n),2,_))-1)*[block_sizeY]/2},
    {100% - [content_marginX] - TOKENIZE((type_l_p_n),3,_)*[block_sizeX]/2},
    {[content_startY]+((2*TOKENIZE((type_l_p_n),2,_))-1)*[block_sizeY]/2},
    {TOKENIZE((type_l_p_n),3,_)*[block_sizeX]}, [block_sizeY], TOKENIZE((type_l_p_n),4,_))}

<actionFrame> = <content, TS, [block_sizeY]>
RECTANGLE = [all], <actionFrame>, #eeeeee
LINE = [all], <actionFrame, PTL>, <actionFrame, PTR>, #000000
LINE =[all], <action_*_frame_1, PTR>, <action_*_frame_1, PBR>, #000000
LINE =[all], <action_*_frame_2, PTR>, <action_*_frame_2, PBR>, #000000
LINE =[all], <action_*_frame_3, PTR>, <action_*_frame_3, PBR>, #000000
TEXT = [all], "[theme{TOKENIZE(Á, 6, _)}]", <theme*_frame_*>, center, wwcenter

<themeFrame> = <content, TS, [block_sizeY]>
LINE = [all], <themeFrame, PTL>, <themeFrame, PTR>, #00000
LINE =[all], <theme_*_frame_1, PTR>, <theme_*_frame_1, PBR>, #000000
LINE =[all], <theme_*_frame_2, PTR>, <theme_*_frame_2, PBR>, #000000
LINE =[all], <theme_*_frame_3, PTR>, <theme_*_frame_3, PBR>, #000000
TEXT = [all], "[action{TOKENIZE(Á, 6, _)}]", <action*_frame_*>, center, wwcenter

